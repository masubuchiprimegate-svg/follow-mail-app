# Required for lead registration and draft persistence.
NEXT_PUBLIC_SUPABASE_URL=

# Currently optional in this MVP UI, but useful when adding Supabase Auth later.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required on the server side. Never expose this key in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Required for AI email generation.
GEMINI_API_KEY=

# Optional at first. Fill these only when you want Outlook draft saving.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_USER_ID=
